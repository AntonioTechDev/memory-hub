# Local agent hook -> TencentDB Gateway
AGENT_MEMORY_BACKEND=tencentdb
AGENT_MEMORY_TENCENT_URL=http://127.0.0.1:8420
AGENT_MEMORY_TENCENT_API_KEY=replace-with-a-random-secret
AGENT_MEMORY_USER_ID=automa-owner
AGENT_MEMORY_BACKEND_TIMEOUT=2

# Gateway process (keep the same bearer secret)
TDAI_GATEWAY_HOST=127.0.0.1
TDAI_GATEWAY_PORT=8420
TDAI_GATEWAY_API_KEY=replace-with-a-random-secret
TDAI_DATA_DIR=/var/lib/automa-agent-memory
TDAI_GATEWAY_CONFIG=/etc/automa/tdai-gateway.json

# Required only for L1/L2/L3 extraction. L0 exact/keyword history works without it.
# TDAI_LLM_API_KEY=
# TDAI_LLM_BASE_URL=https://api.openai.com/v1
# TDAI_LLM_MODEL=gpt-5-mini
